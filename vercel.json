{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    { "src": "api/[...path].js", "use": "@vercel/node" },
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/api/(.*)$", "dest": "api/[...path].js" },
    { "handle": "filesystem" },
    { "src": "^/flight$", "dest": "/flight/dashboard.html" },
    { "src": "^/logistics$", "dest": "/logistics/dashboard.html" },
    { "src": "^/admin/login$", "dest": "/management.html" },
    { "src": "^/admin$", "status": 302, "headers": { "Location": "/admin/login" } },
    { "src": "^/management$", "status": 302, "headers": { "Location": "/admin/login" } },
    { "src": "^/scan$", "dest": "/scan.html" }
  ]
}
