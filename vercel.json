{
  "version": 2,
  "routes": [
    { "src": "^/api/admin/(.*)$", "dest": "/api/admin/[...path].js" },
    { "src": "^/api/user/(.*)$", "dest": "/api/user/[...path].js" },
    { "src": "^/api/public/(.*)$", "dest": "/api/public/[...path].js" },
    { "handle": "filesystem" }
  ],
  "builds": [
    {
      "src": "api/admin/[...path].js",
      "use": "@vercel/node"
    },
    {
      "src": "api/user/[...path].js",
      "use": "@vercel/node"
    },
    {
      "src": "api/public/[...path].js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "*.png",
      "use": "@vercel/static"
    }
  ]
}
