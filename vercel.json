{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    { "src": "api/[...path].js", "use": "@vercel/node" },
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/[...path].js" },
    { "handle": "filesystem" },
    { "src": "/flight", "dest": "/flights/dashboard/index.html" },
    { "src": "/flights", "dest": "/flights/dashboard/index.html" },
    { "src": "/logistics", "dest": "/logistics/dashboard/index.html" }
  ]
}
