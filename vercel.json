{
  "version": 2,
  "routes": [
    { "src": "^/api/(.*)$", "dest": "/api/[...path].js" },
    { "handle": "filesystem" }
  ],
  "builds": [
    {
      "src": "api/[...path].js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.png",
      "use": "@vercel/static"
    }
  ]
}

