<!DOCTYPE html>
<html lang="en" data-default-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TRIP Logistics | Courier Login</title>
    <link rel="stylesheet" href="/assets/css/app.css">
    <script>
        window.TRIP_API_BASE = 'https://hybe-portal.vercel.app';
        try { localStorage.setItem('trip_api_base', window.TRIP_API_BASE); } catch {}
    </script>
</head>
<body>
    <div class="login-shell">
        <div class="login-card">
            <div class="login-brand">
                <img class="trip-logo" src="/logo.png" alt="TRIP Logistics">
                <div>
                    <h1>TRIP Logistics</h1>
                    <div style="color:var(--text-dim); font-weight:700; font-size:0.8rem; margin-top:2px;">Courier Access</div>
                </div>
            </div>

            <p class="login-sub">Sign in with your provisioned Username and Access PIN.</p>

            <form id="loginForm" class="login-row">
                <div>
                    <label style="display:block; font-weight:800; font-size:0.7rem; letter-spacing:1px; color:var(--text-dim); text-transform:uppercase; margin:0 0 8px;">Username</label>
                    <input id="username" type="text" inputmode="text" autocomplete="username" required>
                </div>
                <div>
                    <label style="display:block; font-weight:800; font-size:0.7rem; letter-spacing:1px; color:var(--text-dim); text-transform:uppercase; margin:0 0 8px;">Access PIN</label>
                    <input id="pin" type="password" inputmode="numeric" autocomplete="current-password" required>
                </div>

                <div class="login-actions">
                    <button class="btn-prime" type="submit" id="loginBtn">Login</button>
                    <div class="login-msg" id="loginMsg"></div>
                    <div class="verify-wrap" id="verifyWrap">
                        <div class="spinner"></div>
                        <div style="font-weight:800; letter-spacing:0.2px;">Securely Verifying...</div>
                    </div>
                </div>
            </form>

            <div style="margin-top:14px; color:var(--text-dim); font-weight:800; font-size:0.85rem; text-align:center;">
                Access is provisioned by your operations team. Use your assigned Username and PIN.
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/appwrite@13.0.0"></script>
    <script src="/assets/js/appwrite.js"></script>
    <script src="/assets/js/app.js"></script>
    <script>
        function setBusy(isBusy) {
            document.getElementById('loginBtn').disabled = isBusy;
            document.getElementById('username').disabled = isBusy;
            document.getElementById('pin').disabled = isBusy;
            document.getElementById('verifyWrap').style.display = isBusy ? 'flex' : 'none';
        }

        document.addEventListener('DOMContentLoaded', async () => {
            const form = document.getElementById('loginForm');
            const msg = document.getElementById('loginMsg');
            const btn = document.querySelector('#loginForm button[type="submit"]');
            const userEl = document.getElementById('username');
            const pinEl = document.getElementById('pin');
            let usernameLocked = false;

            function setOnlineUI() {
                const online = (typeof navigator !== 'undefined' && typeof navigator.onLine === 'boolean') ? navigator.onLine : true;
                if (btn) btn.disabled = !online;
                if (!online) msg.textContent = 'No internet connection detected.';
            }
            window.addEventListener('online', setOnlineUI);
            window.addEventListener('offline', setOnlineUI);
            setOnlineUI();
            try {
                const p = new URLSearchParams(window.location.search);
                const u = String(p.get('u') || '').trim();
                if (u) {
                    userEl.value = u;
                    userEl.readOnly = true;
                    userEl.setAttribute('aria-readonly', 'true');
                    userEl.style.opacity = '0.75';
                    userEl.style.cursor = 'not-allowed';
                    usernameLocked = true;
                    try { pinEl.focus(); } catch {}
                }
            } catch {}

            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                msg.textContent = '';
                const username = userEl.value.trim();
                const pin = pinEl.value.trim();
                if (!username || !pin) {
                    msg.textContent = usernameLocked ? 'Enter your Access PIN.' : 'Enter your Username and Access PIN.';
                    return;
                }
                if (typeof navigator !== 'undefined' && navigator.onLine === false) {
                    msg.textContent = 'No internet connection detected.';
                    return;
                }
                setBusy(true);
                try {
                    const out = await userLogin(username, pin);
                    sessionStorage.setItem('active_session', out && out.username ? out.username : username);
                    sessionStorage.setItem('system', 'logistics');
                    let cat = out && out.serviceCategory ? String(out.serviceCategory).toUpperCase() : '';
                    if (!cat) {
                        const me = await userMe();
                        cat = serviceCategoryOf(me && me.userData);
                    }
                    if (cat !== 'LOGISTICS') {
                        try { await userLogout(); } catch {}
                        sessionStorage.removeItem('active_session');
                        sessionStorage.removeItem('system');
                        setBusy(false);
                        msg.textContent = 'This account is not authorized for Logistics access.';
                        return;
                    }
                    window.location.href = '/logistics/dashboard/index.html';
                } catch (e) {
                    setBusy(false);
                    if (e && e.status === 0) {
                        const online = (typeof navigator !== 'undefined' && typeof navigator.onLine === 'boolean') ? navigator.onLine : null;
                        msg.textContent = (e && e.payload && e.payload.hint)
                            ? e.payload.hint
                            : (online === false ? 'No internet connection detected.' : 'Network changed or server unreachable. Try again.');
                        return;
                    }
                    if (e && (e.status === 401 || e.status === 403)) {
                        msg.textContent = 'Invalid Username or PIN';
                        return;
                    }
                    if (e && (e.status === 500 || e.status === 503)) {
                        msg.textContent = 'Login service unavailable';
                        return;
                    }
                    if (e && e.payload && e.payload.error) {
                        msg.textContent = e.payload.error;
                        return;
                    }
                    msg.textContent = 'Login failed.';
                }
            });
        });
    </script>
</body>
</html>
