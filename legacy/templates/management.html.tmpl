            function parseMoney(v) {
                const s = String(v || '').replace(/[^0-9.\-]/g, '');
                const n = Number(s);
                return Number.isFinite(n) ? n : 0;
            }

            function fmtMoney(n) {
                const v = Number(n);
                return (Number.isFinite(v) ? v : 0).toFixed(2);
            }

            async function applyLedgerDelta(sign) {
                const msg = document.getElementById('finMsg');
                msg.textContent = '';
                const username = document.getElementById('finUser').value;
                if (!username) return;
                const deltaRaw = document.getElementById('finDelta').value.trim();
                const delta = Math.abs(parseMoney(deltaRaw));
                if (!delta) {
                    msg.textContent = 'Enter an amount to adjust.';
                    return;
                }
                const db = await loadAllUsersFromDB();
                if (!db.users[username]) return;
                const user = ensureUserShape(db.users[username]);
                const current = parseMoney(user.ledger.balance);
                const next = current + (sign * delta);
                user.ledger.balance = fmtMoney(next);
                user.ledger.transactions = Array.isArray(user.ledger.transactions) ? user.ledger.transactions : [];
                const date = new Date().toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' });
                const amt = `${sign > 0 ? '+' : '-'}£${fmtMoney(delta)}`;
                user.ledger.transactions.push({ date, desc: sign > 0 ? 'Admin Credit' : 'Admin Debit', amount: amt });
                await saveUserToDB(username, user);
                document.getElementById('finBalance').value = user.ledger.balance;
                document.getElementById('finDelta').value = '';
                msg.textContent = sign > 0 ? 'Funds added.' : 'Funds subtracted.';
                await hydrateLedger(username);
                await renderRegistry();
            }

