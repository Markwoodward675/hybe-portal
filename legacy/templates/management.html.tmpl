                    <div class="two-col" style="margin-top:10px;">
                        <button class="btn-primary" type="button" id="btnSchemaSync">Schema Sync (Create/Update)</button>
                        <button class="btn-secondary" type="button" id="btnSchemaInspect">Inspect Schemas</button>
                    </div>
                    <div id="schemaMsg" style="margin-top:12px; color:var(--text-dim); font-weight:800; min-height:22px;"></div>
                    <pre id="schemaOut" style="margin-top:12px; padding:12px; border:1px solid var(--border); border-radius:14px; background: var(--input-bg); color:var(--text); font-weight:800; font-size:0.75rem; overflow:auto; max-height:340px; display:none;"></pre>
                </div>
            </section>
        </main>
    </div>
    </div> <!-- End adminAppContent -->

    <script src="https://cdn.jsdelivr.net/npm/appwrite@13.0.0"></script>
    <script src="appwrite.js"></script>
    <script>
        function makeDefaultLogistics() {
            return ensureLogisticsShape({});
        }

        function makeOneTimeTrackingCode() {
            const alphabet = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
            const bytes = new Uint8Array(8);
            if (window.crypto && window.crypto.getRandomValues) {
                window.crypto.getRandomValues(bytes);
            } else {
                for (let i = 0; i < bytes.length; i++) bytes[i] = Math.floor(Math.random() * 256);
            }
            let out = 'TRIP-';
            for (let i = 0; i < bytes.length; i++) out += alphabet[bytes[i] % alphabet.length];
            return out;
        }

        function makeOneTimeLogisticsCode() {
            const alphabet = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
            const bytes = new Uint8Array(8);
            if (window.crypto && window.crypto.getRandomValues) {
                window.crypto.getRandomValues(bytes);
            } else {
                for (let i = 0; i < bytes.length; i++) bytes[i] = Math.floor(Math.random() * 256);
            }
            let out = 'LGX-';
            for (let i = 0; i < bytes.length; i++) out += alphabet[bytes[i] % alphabet.length];
            return out;
        }

        function makeEventId(prefix) {
            const p = String(prefix || 'evt');
            if (window.crypto && typeof window.crypto.randomUUID === 'function') return `${p}_${window.crypto.randomUUID()}`;
            return `${p}_${Date.now()}_${Math.floor(Math.random() * 1e9)}`;
        }

        function normalizeSlugToken(s) {
            return String(s || '')
                .toLowerCase()
                .replace(/[^a-z0-9]+/g, '_')
                .replace(/^_+|_+$/g, '')
                .slice(0, 18);
        }

        function genPin(digits) {
            const n = Math.max(6, Math.min(8, parseInt(String(digits || 6), 10) || 6));
            const max = Math.pow(10, n);
            const v = Math.floor(Math.random() * max);
            return String(v).padStart(n, '0');
        }

        function genPNR() {
            const alphabet = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
            const bytes = new Uint8Array(6);
            if (window.crypto && window.crypto.getRandomValues) window.crypto.getRandomValues(bytes);
            let out = '';
            for (let i = 0; i < bytes.length; i++) out += alphabet[bytes[i] % alphabet.length];
            return out;
        }

        function genSeq() {
            return String(Math.floor(1 + Math.random() * 9999)).padStart(4, '0');
        }

        function fmtHHMM(d) {
            try {
                return new Intl.DateTimeFormat('en-GB', { hour: '2-digit', minute: '2-digit', hour12: false }).format(d);
            } catch {
                const h = String(d.getHours()).padStart(2, '0');
                const m = String(d.getMinutes()).padStart(2, '0');
                return `${h}:${m}`;
            }
        }

        function ensureFlightDocFields(user) {
            ensureFlightShape(user);
            user.flight.schedule = user.flight.schedule && typeof user.flight.schedule === 'object' ? user.flight.schedule : {};
            user.flight.boarding = user.flight.boarding && typeof user.flight.boarding === 'object' ? user.flight.boarding : {};

            if (!String(user.flight.schedule.pnr || '').trim()) user.flight.schedule.pnr = genPNR();
            if (!String(user.flight.schedule.seq || '').trim()) user.flight.schedule.seq = genSeq();
            if (!String(user.flight.boarding.group || '').trim()) user.flight.boarding.group = String.fromCharCode(65 + Math.floor(Math.random() * 5));

            const dep = String(user.flight.schedule.departAt || '').trim();
            if (!String(user.flight.schedule.boardAt || '').trim()) {
                const dt = dep ? new Date(dep) : null;
                if (dt && !Number.isNaN(dt.getTime())) {
                    user.flight.schedule.boardAt = fmtHHMM(new Date(dt.getTime() - 45 * 60 * 1000));
                }
            }
            return user;
        }

        function ensureUserShape(user) {
            const u = user || {};
            const cat = String(u.serviceCategory || u.service_category || 'FLIGHT').toUpperCase();
            u.serviceCategory = cat === 'LOGISTICS' ? 'LOGISTICS' : 'FLIGHT';
            if (!u.manifest) {
                u.manifest = { from: "LHR", to: "ICN", gate: "--", seat: "--", flightClass: "Business", status: "PENDING" };
            }
            if (!u.ledger) {
                u.ledger = { balance: "0.00", currency: "£", transactions: [] };
            }
            if (!u.logistics) {
                u.logistics = makeDefaultLogistics();
            } else {
                u.logistics = ensureLogisticsShape(u.logistics);
            }
            if (!u.profile) {
                u.profile = { category: "", purpose: "", notes: "", nationality: "", passport: "", gateway: {}, additionalPassengers: [] };
            } else {
                if (!u.profile.gateway || typeof u.profile.gateway !== 'object') u.profile.gateway = {};
                if (!Array.isArray(u.profile.additionalPassengers)) u.profile.additionalPassengers = [];
            }
            if (!u.verification || typeof u.verification !== 'object') {
                u.verification = { stageIndex: 1, final: "", updatedAt: null };
            } else {
                if (typeof u.verification.stageIndex !== 'number') u.verification.stageIndex = 1;
                if (typeof u.verification.final !== 'string') u.verification.final = "";
            }
            if (!u.logisticsManifest || typeof u.logisticsManifest !== 'object') {
                u.logisticsManifest = {
                    waybillId: "",
                    cargoWeight: "",
                    vehicleType: "",
                    deliveryEstimate: "",
                    originAddress: "",
                    destinationAddress: "",
                    courierId: ""
                };
            }
            if (!u.form || typeof u.form !== 'object') {
                u.form = { flightNo: "", departAt: "", notes: "", lockedByAdmin: true, signature: null, updatedAt: null };
            } else {
                if (typeof u.form.flightNo !== 'string') u.form.flightNo = "";
                if (typeof u.form.departAt !== 'string') u.form.departAt = "";
                if (typeof u.form.notes !== 'string') u.form.notes = "";
                if (typeof u.form.lockedByAdmin !== 'boolean') u.form.lockedByAdmin = true;
            }
            if (!u.share) {
                u.share = { oneTimeTracking: { code: "", createdAt: null, usedAt: null } };
            } else {
                if (!u.share.oneTimeTracking) u.share.oneTimeTracking = { code: "", createdAt: null, usedAt: null };
                if (typeof u.share.oneTimeTracking !== 'object') u.share.oneTimeTracking = { code: "", createdAt: null, usedAt: null };
            }
            if (!u.share.oneTimeLogistics || typeof u.share.oneTimeLogistics !== 'object') {
                u.share.oneTimeLogistics = { code: "", createdAt: null, usedAt: null };
            }
            return u;
        }

        async function requireAdminSession() {
            try {
                const out = await adminMe();
                if (out && out.ok) {
                    document.getElementById('adminAuthOverlay').style.display = 'none';
                    document.getElementById('adminAppContent').style.display = 'block';
                    requestAnimationFrame(() => { document.body.style.opacity = '1'; });
                    return true;
                }
            } catch {}

            requestAnimationFrame(() => { document.body.style.opacity = '1'; });
            return false;
        }

        function setSection(targetId) {
            document.querySelectorAll('.admin-sec').forEach((sec) => {
                sec.style.display = sec.id === targetId ? 'block' : 'none';
            });
            document.querySelectorAll('.admin-menu button').forEach((btn) => {
                btn.classList.toggle('active', btn.dataset.target === targetId);
            });
            const shortcuts = document.getElementById('adminMobileShortcuts');
            if (shortcuts) {
                shortcuts.querySelectorAll('button').forEach((btn) => {
                    btn.classList.toggle('active', btn.dataset.target === targetId);
                });
            }
            if (targetId === 'secSubmissions') {
                renderSubmissions();
            }
            if (targetId === 'secNotifications') {
                renderNotifications();
                loadLivePopupsAdmin();
            }
            if (targetId === 'secBoardingPass') {
                hydrateBoardingPass(document.getElementById('bpUser') && document.getElementById('bpUser').value);
            }
            if (typeof onUserChange === 'function') {
                onUserChange();
            }
        }

        function getUsersSorted(db) {
            return Object.keys(db.users || {}).sort((a, b) => a.localeCompare(b));
        }

        async function refreshUserSelects() {
            const db = await loadAllUsersFromDB();
            const usernames = getUsersSorted(db);
            document.querySelectorAll('.user-select').forEach((sel) => {
                const current = sel.value;
                sel.innerHTML = '';
                if (usernames.length === 0) {
                    const opt = document.createElement('option');
                    opt.value = '';
                    opt.textContent = 'No users provisioned';
                    sel.appendChild(opt);
                    sel.disabled = true;
                    return;
                }
                sel.disabled = false;
                usernames.forEach((u) => {
                    const opt = document.createElement('option');
                    opt.value = u;
                    opt.textContent = u;
                    sel.appendChild(opt);
                });
                if (current && usernames.includes(current)) sel.value = current;
            });
        }

        async function renderRegistry() {
            const db = await loadAllUsersFromDB();
            const body = document.getElementById('registryBody');
            body.innerHTML = '';
            const usernames = getUsersSorted(db);
            usernames.forEach((username) => {
                const user = ensureUserShape(db.users[username]);
                const route = `${user.manifest.from || '--'}-${user.manifest.to || '--'}`;
                const gs = `${user.manifest.gate || '--'} / ${user.manifest.seat || '--'}`;
                const cur = (user.ledger && user.ledger.currency) ? String(user.ledger.currency) : '£';
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td style="font-weight:900;">
                        <button type="button" class="btn-open-user" data-user="${username}" style="background:transparent; border:none; padding:0; color:var(--text); font-weight:900; cursor:pointer; text-decoration:underline; text-underline-offset:3px;">
                            ${username}
                        </button>
                    </td>
                    <td style="font-weight:900;">${user.pin}</td>
                    <td>${user.passengerName || '--'}</td>
                    <td style="font-weight:900; color:var(--text-dim);">${String(user.serviceCategory || 'FLIGHT').toUpperCase()}</td>
                    <td><span class="badge-pill" style="color:${user.manifest.status === 'CONFIRMED' ? 'var(--success)' : (user.manifest.status === 'CANCELLED' ? 'var(--danger)' : 'var(--warning)')}; border-color:${user.manifest.status === 'CONFIRMED' ? 'var(--success)' : (user.manifest.status === 'CANCELLED' ? 'var(--danger)' : 'var(--warning)')};">${user.manifest.status}</span></td>
                    <td>${route}</td>
                    <td>${gs}</td>
                    <td style="color:var(--text-dim); font-weight:900;">${String(user.manifest.flightClass || '').toUpperCase()}</td>
                    <td style="font-weight:900;">${cur}${user.ledger.balance}</td>
                    <td style="white-space:nowrap;">
                        <button class="btn-secondary btn-mini btn-open-user" type="button" data-user="${username}" data-open="secManifest">Open</button>
                        <button class="btn-secondary btn-mini btn-open-user" type="button" data-user="${username}" data-open="secFinancial">Finance</button>
                        <button class="btn-secondary btn-mini btn-delete-user" type="button" data-user="${username}" style="border-color: rgba(239,68,68,0.35); color: var(--danger);">Delete</button>
                    </td>
                `;
                body.appendChild(tr);
            });

            const openUser = async (u, target) => {
                const username = String(u || '').trim();
                if (!username) return;
                document.querySelectorAll('.user-select').forEach((sel) => { sel.value = username; });
                if (typeof onUserChange === 'function') onUserChange();
                if (target) setSection(String(target));
                else setSection('secManifest');
                try { toast(`Loaded: ${username}`, 'ok'); } catch {}
                try { window.scrollTo({ top: 0, behavior: 'smooth' }); } catch {}
            };

            document.querySelectorAll('.btn-open-user').forEach((btn) => {
                btn.addEventListener('click', async (e) => {
                    const u = e.currentTarget.getAttribute('data-user');
                    const target = e.currentTarget.getAttribute('data-open');
                    await openUser(u, target);
                });
            });

            // Attach delete listeners
            document.querySelectorAll('.btn-delete-user').forEach(btn => {
                btn.addEventListener('click', async (e) => {
                    const u = e.target.getAttribute('data-user');
                    if (confirm(`Delete user ${u}? This will permanently remove the profile from Appwrite (and local fallback if present).`)) {
                        try {
                            const out = await tripApi(`/api/admin/users/${encodeURIComponent(u)}`, { method: 'DELETE' });
                            if (!out || out.ok !== true) {
                                try { toast('Delete failed. Re-run Schema Ensure and try again.', 'bad'); } catch {}
                                return;
                            }
                        } catch (err) {
                            try { toast((err && err.payload && err.payload.error) ? err.payload.error : 'Delete failed.', 'bad'); } catch {}
                            return;
                        }

                        try {
                            const localDb = loadFromLocal();
                            const key = Object.keys(localDb.users || {}).find((k) => String(k).toLowerCase() === String(u).toLowerCase());
                            if (key) delete localDb.users[key];
                            localStorage.setItem('trip_users_db', JSON.stringify(localDb));
                        } catch {}
                        
                        await refreshUserSelects();
                        await renderRegistry();
                        try { toast(`Deleted: ${u}`, 'ok'); } catch {}
                    }
                });
            });

            setTimeout(async () => {
                const missing = [];
                usernames.forEach((username) => {
                    const user = ensureUserShape(db.users[username]);
                    const share = user.share && typeof user.share === 'object' ? user.share : {};
                    const tA = share.oneTimeTracking && share.oneTimeTracking.code ? String(share.oneTimeTracking.code) : '';
                    const tB = share.oneTimeLogistics && share.oneTimeLogistics.code ? String(share.oneTimeLogistics.code) : '';
                    if (!tA || !tB) missing.push(username);
                });
                if (!missing.length) return;

                const createdAt = new Date().toISOString();
                const limit = 3;
                let idx = 0;
                const runOne = async () => {
                    const username = missing[idx++];
                    if (!username) return;
                    const user = ensureUserShape(db.users[username]);
                    user.share = user.share && typeof user.share === 'object' ? user.share : {};
                    const share = user.share;
                    if (!share.oneTimeTracking || !share.oneTimeTracking.code) {
                        share.oneTimeTracking = {
                            code: makeOneTimeTrackingCode(),
                            createdAt,
                            usedAt: null
                        };
                    }
                    if (!share.oneTimeLogistics || !share.oneTimeLogistics.code) {
                        share.oneTimeLogistics = {
                            code: makeOneTimeLogisticsCode(),
                            createdAt,
                            usedAt: null
                        };
                    }
                    try {
                        await tripApi(`/api/admin/users/${encodeURIComponent(username)}`, { method: 'PATCH', body: { userData: user } });
                        try {
                            const localDb = loadFromLocal();
                            localDb.users = localDb.users && typeof localDb.users === 'object' ? localDb.users : {};
                            localDb.users[username] = user;
                            localStorage.setItem('trip_users_db', JSON.stringify(localDb));
                        } catch {}
                    } catch {}
                };
                const workers = [];
                for (let i = 0; i < Math.min(limit, missing.length); i++) {
                    workers.push((async function loop() { while (idx < missing.length) await runOne(); })());
                }
                await Promise.all(workers);
            }, 0);
        }

        async function renderSubmissions() {
            const body = document.getElementById('subBody');
            const msg = document.getElementById('subMsg');
            if (!body) return;
            body.innerHTML = '';
            if (msg) msg.textContent = 'Loading submissions...';

            let out = null;
            try {
                out = await tripApi('/api/admin/submissions', { method: 'GET' });
            } catch (e) {
                if (msg) msg.textContent = 'Unable to load submissions.';
                return;
            }

            const items = out && Array.isArray(out.items) ? out.items : [];
            const badge = (status) => {
                const st = String(status || 'PENDING').toUpperCase();
                const c = st === 'APPROVED' ? 'var(--success)' : (st === 'REJECTED' ? 'var(--danger)' : 'var(--warning)');
                const bg = st === 'APPROVED' ? 'rgba(16,185,129,0.10)' : (st === 'REJECTED' ? 'rgba(239,68,68,0.10)' : 'rgba(245,158,11,0.10)');
                return `<span class="badge-pill" style="color:${c}; border-color:${c}; background:${bg};">${st}</span>`;
            };

            items.forEach((it) => {
                const tr = document.createElement('tr');
                const when = it.submittedAt ? new Date(it.submittedAt).toLocaleString() : '—';
                const sigBtn = it.signature && it.signature.dataUrl ? `<button class="btn-secondary btn-view-sig" type="button" data-url="${it.signature.dataUrl}">View</button>` : '—';
                tr.innerHTML = `
                    <td style="font-weight:900;">${String(it.type || '').toUpperCase()}</td>
                    <td style="font-weight:900;">${it.username}</td>
                    <td>${it.title || '—'}</td>
                    <td>${badge(it.status)}</td>
                    <td style="color:var(--text-dim); font-weight:800;">${when}</td>
                    <td>${sigBtn}</td>
                    <td>
                        <button class="btn-secondary btn-sub-status" type="button" data-u="${it.username}" data-t="${it.type}" data-id="${it.id}" data-s="APPROVED">Approve</button>
                        <button class="btn-secondary btn-sub-status" type="button" data-u="${it.username}" data-t="${it.type}" data-id="${it.id}" data-s="REJECTED">Reject</button>
                    </td>
                `;
                body.appendChild(tr);
            });

            if (!items.length) {
                const tr = document.createElement('tr');
                tr.innerHTML = `<td colspan="7" style="color:var(--text-dim); font-weight:800; padding:14px;">No submissions.</td>`;
                body.appendChild(tr);
            }

            document.querySelectorAll('.btn-view-sig').forEach((b) => {
                b.addEventListener('click', (e) => {
                    const url = e.currentTarget.getAttribute('data-url');
                    const w = window.open('', '_blank');
                    if (!w) return;
                    w.document.write(`<img src="${url}" style="max-width:100%; height:auto;">`);
                    w.document.close();
                });
            });

            document.querySelectorAll('.btn-sub-status').forEach((b) => {
                b.addEventListener('click', async (e) => {
                    const u = e.currentTarget.getAttribute('data-u');
                    const t = e.currentTarget.getAttribute('data-t');
                    const id = e.currentTarget.getAttribute('data-id');
                    const s = e.currentTarget.getAttribute('data-s');
                    if (msg) msg.textContent = 'Updating...';
                    try {
                        await tripApi('/api/admin/submissions', { method: 'PATCH', body: { username: u, type: t, id, status: s } });
                        if (msg) msg.textContent = 'Updated.';
                        renderSubmissions();
                    } catch {
                        if (msg) msg.textContent = 'Update failed.';
                    }
                });
            });

            if (msg) msg.textContent = '';
        }

        async function renderNotifications() {
            const body = document.getElementById('ntBody');
            const msg = document.getElementById('ntMsg');
            if (!body) return;
            body.innerHTML = '';
            if (msg) msg.textContent = 'Loading notifications...';

            let out = null;
            try {
                out = await tripApi('/api/admin/notifications', { method: 'GET' });
            } catch {
                if (msg) msg.textContent = 'Unable to load notifications.';
                return;
            }

            const items = out && Array.isArray(out.items) ? out.items : [];
            items.forEach((it) => {
                const tr = document.createElement('tr');
                const created = it.createdAt ? new Date(it.createdAt).toLocaleString() : '—';
                tr.innerHTML = `
                    <td style="font-weight:900;">${it.title || '—'}</td>
                    <td>${it.message || '—'}</td>
                    <td style="font-weight:900; color:var(--text-dim);">${it.tone || 'accent'}</td>
                    <td style="font-weight:900;">${it.active ? 'true' : 'false'}</td>
                    <td style="color:var(--text-dim); font-weight:800;">${created}</td>
                    <td>
                        <button class="btn-secondary btn-nt-toggle" type="button" data-id="${it.id}" data-active="${it.active ? 'true' : 'false'}">${it.active ? 'Disable' : 'Enable'}</button>
                        <button class="btn-secondary btn-nt-del" type="button" data-id="${it.id}">Delete</button>
                    </td>
                `;
                body.appendChild(tr);
            });

            if (!items.length) {
                const tr = document.createElement('tr');
                tr.innerHTML = `<td colspan="6" style="color:var(--text-dim); font-weight:800; padding:14px;">No notifications.</td>`;
                body.appendChild(tr);
            }

            document.querySelectorAll('.btn-nt-toggle').forEach((b) => {
                b.addEventListener('click', async (e) => {
                    const id = e.currentTarget.getAttribute('data-id');
                    const active = e.currentTarget.getAttribute('data-active') !== 'true';
                    if (msg) msg.textContent = 'Updating...';
                    try {
                        await tripApi('/api/admin/notifications', { method: 'PATCH', body: { id, active } });
                        if (msg) msg.textContent = '';
                        renderNotifications();
                    } catch {
                        if (msg) msg.textContent = 'Update failed.';
                    }
                });
            });

            document.querySelectorAll('.btn-nt-del').forEach((b) => {
                b.addEventListener('click', async (e) => {
                    const id = e.currentTarget.getAttribute('data-id');
                    if (!confirm('Delete this notification?')) return;
                    if (msg) msg.textContent = 'Deleting...';
                    try {
                        await tripApi(`/api/admin/notifications/${encodeURIComponent(id)}`, { method: 'DELETE' });
                        if (msg) msg.textContent = '';
                        renderNotifications();
                    } catch {
                        if (msg) msg.textContent = 'Delete failed.';
                    }
                });
            });

            if (msg) msg.textContent = '';
        }

        function safeJsonParse(s) {
            try { return JSON.parse(String(s || '')); } catch { return null; }
        }

        function setLPStats(pool) {
            const el = document.getElementById('lpStats');
            if (!el) return;
            const items = pool && Array.isArray(pool.items) ? pool.items.length : 0;
            const interval = pool && pool.intervalSeconds ? pool.intervalSeconds : '—';
            const enabled = pool && pool.enabled !== false;
            el.textContent = `${enabled ? 'Enabled' : 'Disabled'} • ${items} items • ${interval}s`;
        }

        async function loadLivePopupsAdmin() {
            const msg = document.getElementById('lpMsg');
            if (msg) msg.textContent = 'Loading...';
            try {
                const out = await tripApi('/api/admin/live-popups', { method: 'GET' });
                document.getElementById('lpEnabled').value = out && out.enabled === false ? 'false' : 'true';
                document.getElementById('lpInterval').value = String((out && out.intervalSeconds) ? out.intervalSeconds : 30);
                document.getElementById('lpCount').value = String((out && out.items && out.items.length) ? out.items.length : 1200);
                const startAt = out && out.startAt ? new Date(out.startAt) : null;
                const validUntil = out && out.validUntil ? new Date(out.validUntil) : null;
                const days = (startAt && validUntil && !Number.isNaN(startAt.getTime()) && !Number.isNaN(validUntil.getTime()))
                    ? Math.max(1, Math.round((validUntil.getTime() - startAt.getTime()) / 86400000))
                    : 7;
                document.getElementById('lpDays').value = String(days);
                setLPStats(out);
                if (msg) msg.textContent = '';
            } catch {
                if (msg) msg.textContent = 'Unable to load live popups.';
            }
        }

        async function generateLivePopupsAdmin() {
            const msg = document.getElementById('lpMsg');
            if (msg) msg.textContent = 'Generating...';
            const count = parseInt(document.getElementById('lpCount').value, 10) || 1200;
            const intervalSeconds = parseInt(document.getElementById('lpInterval').value, 10) || 30;
            const days = parseInt(document.getElementById('lpDays').value, 10) || 7;
            try {
                await tripApi('/api/admin/live-popups', { method: 'POST', body: { count, days, intervalSeconds } });
                if (msg) msg.textContent = 'Generated.';
                await loadLivePopupsAdmin();
            } catch {
                if (msg) msg.textContent = 'Generate failed.';
            }
        }

        async function saveLivePopupsSettingsAdmin(enabledOverride) {
            const msg = document.getElementById('lpMsg');
            if (msg) msg.textContent = 'Saving...';
            const enabled = enabledOverride !== undefined ? Boolean(enabledOverride) : (document.getElementById('lpEnabled').value === 'true');
            const intervalSeconds = parseInt(document.getElementById('lpInterval').value, 10) || 30;
            try {
                await tripApi('/api/admin/live-popups', { method: 'PATCH', body: { enabled, intervalSeconds } });
                if (msg) msg.textContent = 'Saved.';
                await loadLivePopupsAdmin();
            } catch {
                if (msg) msg.textContent = 'Save failed.';
            }
        }

        async function patchLivePopupItemAdmin(isDelete) {
            const msg = document.getElementById('lpMsg');
            if (msg) msg.textContent = isDelete ? 'Deleting...' : 'Updating...';
            const index = parseInt(document.getElementById('lpEditIndex').value, 10);
            if (!Number.isFinite(index)) {
                if (msg) msg.textContent = 'Enter a valid index.';
                return;
            }
            if (isDelete) {
                try {
                    await tripApi('/api/admin/live-popups', { method: 'PATCH', body: { deleteIndex: index } });
                    if (msg) msg.textContent = 'Deleted.';
                    await loadLivePopupsAdmin();
                } catch {
                    if (msg) msg.textContent = 'Delete failed.';
                }
                return;
            }
            const patch = safeJsonParse(document.getElementById('lpEditJson').value);
            if (!patch || typeof patch !== 'object') {
                if (msg) msg.textContent = 'Invalid JSON patch.';
                return;
            }
            try {
                await tripApi('/api/admin/live-popups', { method: 'PATCH', body: { index, item: patch } });
                if (msg) msg.textContent = 'Updated.';
                await loadLivePopupsAdmin();
            } catch {
                if (msg) msg.textContent = 'Update failed.';
            }
        }

