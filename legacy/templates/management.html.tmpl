                    renderNotifications();
                } catch {
                    msg.textContent = 'Create failed.';
                }
            });
            if (btnReloadNotif) btnReloadNotif.addEventListener('click', renderNotifications);

            const btnLoadLP = document.getElementById('btnLoadLP');
            const btnGenLP = document.getElementById('btnGenLP');
            const btnSaveLP = document.getElementById('btnSaveLP');
            const btnDisableLP = document.getElementById('btnDisableLP');
            const btnPatchLP = document.getElementById('btnPatchLP');
            const btnDelLP = document.getElementById('btnDelLP');
            if (btnLoadLP) btnLoadLP.addEventListener('click', loadLivePopupsAdmin);
            if (btnGenLP) btnGenLP.addEventListener('click', generateLivePopupsAdmin);
            if (btnSaveLP) btnSaveLP.addEventListener('click', () => saveLivePopupsSettingsAdmin());
            if (btnDisableLP) btnDisableLP.addEventListener('click', () => saveLivePopupsSettingsAdmin(false));
            if (btnPatchLP) btnPatchLP.addEventListener('click', () => patchLivePopupItemAdmin(false));
            if (btnDelLP) btnDelLP.addEventListener('click', () => patchLivePopupItemAdmin(true));

            onUserChange();
        });
    </script>
</body>
</html>
