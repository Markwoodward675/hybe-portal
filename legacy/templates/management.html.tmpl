                        }
                    } catch (e) {
                        if (e && e.status === 401) {
                            const payloadMsg = (e.payload && e.payload.error) ? e.payload.error : null;
                            const hint = (e.payload && typeof e.payload.configured === 'boolean')
                                ? (e.payload.configured ? '' : ' (passcode not set in Vercel env, using default)')
                                : '';
                            const flags = (e.payload && typeof e.payload.configured === 'boolean')
