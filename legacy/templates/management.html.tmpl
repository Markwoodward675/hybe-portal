            document.getElementById('btnSaveLogistics').addEventListener('click', async () => {
                const username = document.getElementById('logUser').value;
                const msg = document.getElementById('logMsg');
                msg.textContent = '';
                if (!username) return;

                const db = await loadAllUsersFromDB();
                if (!db.users[username]) return;
                const user = ensureUserShape(db.users[username]);
                user.logistics = ensureLogisticsShape(user.logistics);
                const currentStep = parseInt(document.getElementById('logCurrent').value, 10);
                const nextStep = Number.isFinite(currentStep) ? currentStep : (user.logistics.currentStep || 2);
                const nextIndex = Math.max(0, Math.min(7, nextStep - 1));
                const sel = document.getElementById('logCurrent');
                const prevIndex = sel && sel.dataset && sel.dataset.prevIndex !== undefined
                    ? Math.max(0, Math.min(7, parseInt(String(sel.dataset.prevIndex), 10)))
                    : user.logistics.currentStepIndex;
                if (prevIndex !== nextIndex) {
                    user.logistics.events = Array.isArray(user.logistics.events) ? user.logistics.events : [];
                    user.logistics.events.push({
                        id: makeEventId('evt'),
                        type: 'SYSTEM_AUTO',
                        fromStepIndex: prevIndex,
                        toStepIndex: nextIndex,
                        createdAt: new Date().toISOString(),
                        createdBy: { role: 'ADMIN' }
                    });
                }
                user.logistics.currentStepIndex = nextIndex;
                user.logistics.currentStep = nextIndex + 1;

                const steps = user.logistics.steps.slice();
                document.querySelectorAll('#stepsEditor input[data-step]').forEach((inp) => {
                    const idx = parseInt(inp.dataset.step, 10);
                    const field = inp.dataset.field;
                    if (!Number.isFinite(idx) || idx < 0 || idx > 7) return;
                    steps[idx] = steps[idx] || { title: '', location: '', date: '' };
                    steps[idx][field] = inp.value.trim();
                });
                user.logistics.steps = steps;
                user.logistics.lastUpdatedAt = new Date().toISOString();
                user.logistics = ensureLogisticsShape(user.logistics);
                
                await saveUserToDB(username, user);
                msg.textContent = 'Tracker saved.';
                if (sel && sel.dataset) sel.dataset.prevIndex = String(nextIndex);
            });

