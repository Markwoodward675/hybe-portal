        async function runAutoUserStatusUpdateIfDue() {
            const now = Date.now();
            const raw = localStorage.getItem('trip_users_autoupdate_next');
            const nextAt = raw ? parseInt(raw, 10) : 0;
            if (nextAt && now < nextAt) return;

            const db = await loadAllUsersFromDB();
            const keys = Object.keys(db.users || {});
            const stages = ['ON-HOLD', 'PENDING', 'VERIFYING', 'VERIFIED'];
            const finals = ['CONFIRMED', 'SUSPENDED', 'REJECTED', 'DECLINED'];

            for (const username of keys) {
                const user = ensureUserShape(db.users[username]);
                const n = String(user.passengerName || '').toLowerCase();
                if (n.includes('clare bland')) continue;
                const currentStatus = String(user.manifest && user.manifest.status ? user.manifest.status : '').toUpperCase();
                const locked = ['VERIFIED', 'CONFIRMED', 'SUSPENDED', 'REJECTED', 'DECLINED', 'CANCELLED'];
                if (locked.includes(currentStatus)) {
                    await saveUserToDB(username, user);
                    continue;
                }
                const vf = user.verification || { stageIndex: 1, final: '', updatedAt: null };
                if (vf.final) {
                    user.manifest.status = vf.final;
                    await saveUserToDB(username, user);
                    continue;
                }

                const stepChance = Math.random();
                if (vf.stageIndex < stages.length - 1) {
                    if (stepChance < 0.75) vf.stageIndex = Math.min(stages.length - 1, vf.stageIndex + 1);
                    vf.updatedAt = new Date().toISOString();
                    user.verification = vf;
                    user.manifest.status = stages[vf.stageIndex] || 'PENDING';
                } else {
                    const roll = Math.random();
                    let out = 'CONFIRMED';
                    if (roll >= 0.70 && roll < 0.82) out = 'SUSPENDED';
                    if (roll >= 0.82 && roll < 0.92) out = 'REJECTED';
                    if (roll >= 0.92) out = 'DECLINED';
                    vf.final = out;
                    vf.updatedAt = new Date().toISOString();
                    user.verification = vf;
                    user.manifest.status = out;
                }
                await saveUserToDB(username, user);
            }

            const next = now + randInt(10, 15) * 60 * 1000;
            localStorage.setItem('trip_users_autoupdate_next', String(next));
        }

