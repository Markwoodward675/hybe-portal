            (function initMobileMenu() {
                const toggleBtn = document.getElementById('adminMobileToggle');
                const menu = document.getElementById('adminMobileMenu');
                const grid = document.getElementById('adminMobileGrid');
                const shortcuts = document.getElementById('adminMobileShortcuts');
                const srcButtons = Array.from(document.querySelectorAll('.admin-menu button'));
                grid.innerHTML = '';
                if (shortcuts) shortcuts.innerHTML = '';
                srcButtons.forEach((b) => {
                    const mb = document.createElement('button');
                    mb.textContent = b.textContent;
                    mb.dataset.target = b.dataset.target;
                    mb.addEventListener('click', () => {
                        setSection(mb.dataset.target);
                        menu.classList.remove('open');
                        if (toggleBtn) toggleBtn.setAttribute('aria-expanded', 'false');
                    });
                    grid.appendChild(mb);

                    if (shortcuts) {
                        const sb = document.createElement('button');
                        sb.type = 'button';
                        sb.textContent = b.textContent;
                        sb.dataset.target = b.dataset.target;
                        sb.addEventListener('click', () => setSection(sb.dataset.target));
                        shortcuts.appendChild(sb);
                    }
                });
                function toggleMenu() {
                    const open = !menu.classList.contains('open');
                    menu.classList.toggle('open', open);
                    if (toggleBtn) toggleBtn.setAttribute('aria-expanded', String(open));
                }
                if (toggleBtn) toggleBtn.addEventListener('click', toggleMenu);
                document.addEventListener('click', (e) => {
                    if (!menu.classList.contains('open')) return;
                    const within = menu.contains(e.target) || (toggleBtn && toggleBtn.contains(e.target));
                    if (!within) menu.classList.remove('open');
                });
            })();

