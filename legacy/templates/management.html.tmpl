<!DOCTYPE html>
<html lang="en" data-force-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <base href="/">
    <title>TRIP Logistics | Admin Command Center</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>✈️</text></svg>">
    <link rel="stylesheet" href="styles.css">
    <script>
        window.TRIP_API_BASE = 'https://hybe-portal.vercel.app';
        try { localStorage.setItem('trip_api_base', window.TRIP_API_BASE); } catch {}
    </script>
    <style>
        @media (max-width: 900px) {
            body { overflow-x: hidden; }
            .trip-nav { flex-wrap: nowrap; height: auto; padding: 10px 12px; }
            .trip-nav-right { width: auto; justify-content: flex-end; flex-wrap: nowrap; gap: 10px; }
            .trip-nav-right > div { display: none; }
            .admin-shell { grid-template-columns: 1fr !important; }
            .admin-sidebar { display: none !important; }
            .admin-mobile-bar { display: none !important; }
            .admin-mobile-menu { display: none !important; }
            .admin-main { padding: 120px 12px 70px !important; }
            .admin-row { grid-template-columns: 1fr !important; }
            .two-col, .three-col { grid-template-columns: 1fr !important; }
            .card { padding: 14px; }
            .login-card { width: min(440px, calc(100vw - 24px)); }
            .table-wrap { overflow-x: hidden !important; }
            .table-wrap .m-table { min-width: 0 !important; }
        }
        .admin-mobile-bar {
            display: none;
            position: fixed;
            top: 74px;
            z-index: 40;
            background: var(--card);
            border-bottom: 1px solid var(--border);
            padding: 8px 12px;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
        }
        .admin-mobile-title {
            font-weight: 900;
            letter-spacing: -0.4px;
        }
        .admin-mobile-actions { display: flex; gap: 8px; }
        .admin-mobile-shortcuts {
            display: flex;
            gap: 8px;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            flex: 1;
            padding-bottom: 2px;
        }
        .admin-mobile-shortcuts::-webkit-scrollbar { height: 0; }
        .admin-mobile-shortcuts button{
            border: 1px solid var(--border);
            background: var(--input-bg);
            color: var(--text);
            font-weight: 900;
            border-radius: 999px;
            padding: 10px 12px;
            cursor: pointer;
            white-space: nowrap;
        }
        .admin-mobile-shortcuts button.active{
            border-color: rgba(30,64,175,0.35);
            background: rgba(30,64,175,0.10);
            color: rgba(30,64,175,1);
        }
        .admin-mobile-menu {
            position: fixed;
            top: 102px;
            left: 0;
            right: 0;
            background: var(--card);
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
            box-shadow: 0 24px 48px rgba(0,0,0,0.12);
            padding: 10px;
            display: none;
            z-index: 45;
        }
        .admin-mobile-menu.open { display: grid; }
        .admin-mobile-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 8px;
        }
        .admin-mobile-menu button {
            width: 100%;
            padding: 10px 12px;
            border-radius: 10px;
            border: 1px solid var(--border);
            background: var(--input-bg);
            color: var(--text);
            font-weight: 800;
            cursor: pointer;
        }
        .admin-actionbar{
            position: sticky;
            bottom: 12px;
            z-index: 25;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            padding: 10px;
            border-radius: 16px;
            border: 1px solid var(--border);
            background: var(--card);
            box-shadow: 0 24px 60px rgba(0,0,0,0.10);
        }
        @media (max-width: 900px) {
            .admin-actionbar{ grid-template-columns: 1fr; }
        }
        @media (max-width: 520px) {
            .admin-main { padding: 112px 10px 64px !important; }
            .admin-mobile-bar { padding: 8px 10px; }
            .admin-mobile-grid { grid-template-columns: 1fr; }
            .admin-mobile-shortcuts button { padding: 9px 10px; font-size: 0.78rem; }
            .admin-mobile-menu { padding: 10px; }
            .card { padding: 12px; }
        }
    </style>
</head>
<body style="opacity:0; transition: opacity 0.5s ease;">
    <!-- Admin Login Overlay -->
    <div id="adminAuthOverlay" class="login-shell" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 9999;">
        <div class="login-card">
            <div class="login-brand">
                <img class="trip-logo" src="logo.png" alt="TRIP Logistics">
                <h1>TRIP Admin Gateway</h1>
            </div>
            <p class="login-sub">Enter the master passcode to access the Closed-Loop Command Center.</p>
            <form id="adminLoginForm" class="login-row">
                <input type="text" autocomplete="username" value="admin" style="position:absolute; left:-9999px; width:1px; height:1px; opacity:0;" aria-hidden="true">
                <div>
                    <div class="ticket-k" style="margin-bottom:8px;">Admin Passcode</div>
                    <input id="adminPassInput" type="password" placeholder="••••••••" autocomplete="current-password">
                </div>
                <div class="login-actions">
                    <button id="btnAdminLogin" class="btn-primary" type="submit">Access Command Center</button>
                </div>
            </form>
            <div id="adminLoginMsg" class="login-msg" style="margin-top:12px; color:var(--danger); text-align:center;"></div>
        </div>
    </div>

    <div id="adminAppContent" style="display:none;">
        <nav class="trip-nav">
        <a href="flight.html" class="trip-brand">
            <img class="trip-logo" src="logo.png" alt="TRIP Logistics">
            <span>TRIP Logistics</span>
        </a>
        <div class="trip-nav-right">
            <div id="adminHeaderTitle" style="color:var(--text-dim); font-weight:800; font-size:0.75rem; letter-spacing:1px; text-transform:uppercase;">Admin Command Center</div>
            <span id="adminSessionPill" class="badge-pill session-pill" style="color:var(--warning); border-color:var(--warning); background: rgba(245,158,11,0.10);">ADMIN</span>
            <button class="nav-signout theme-toggle" id="adminThemeToggle" type="button" aria-label="Toggle theme"></button>
            <button class="nav-toggle" id="adminMobileToggle" type="button" aria-label="Menu" aria-expanded="false">☰</button>
            <button class="nav-signout" id="adminSignOutBtn" type="button">Exit Admin</button>
        </div>
    </nav>
    <div class="admin-mobile-bar">
        <div class="admin-mobile-shortcuts" id="adminMobileShortcuts"></div>
    </div>
    <div class="admin-mobile-menu" id="adminMobileMenu">
        <div class="admin-mobile-grid" id="adminMobileGrid"></div>
    </div>

    <div class="admin-shell">
        <aside class="admin-sidebar">
            <div class="admin-brand">
                <img class="trip-logo" src="logo.png" alt="TRIP Logistics">
                <div>
                    <strong>TRIP Admin</strong>
                    <div style="color:var(--text-dim); font-weight:800; font-size:0.75rem; margin-top:2px;">Closed-Loop Provisioning</div>
                </div>
            </div>

            <div class="admin-menu" role="tablist" aria-label="Admin Sections">
                <button type="button" class="active" data-target="secProvision">User Provisioning</button>
                <button type="button" data-target="secManifest">Manifest Editor</button>
                <button type="button" data-target="secFinancial">Financial Control</button>
                <button type="button" data-target="secLogistics">Logistics Sync</button>
                <button type="button" data-target="secFlightForm">Flight Form</button>
                <button type="button" data-target="secBoardingPass">Boarding Pass</button>
                <button type="button" data-target="secSubmissions">Submissions</button>
                <button type="button" data-target="secNotifications">Notifications</button>
                <button type="button" data-target="secRegistry">User Registry</button>
                <button type="button" data-target="secSettings">Settings</button>
            </div>
        </aside>

        <main class="admin-main">
            <section id="secProvision" class="admin-sec">
                <h2 style="margin:0 0 18px; letter-spacing:-1px;">User Provisioning</h2>
                <div class="card">
                    <form id="pvForm" class="three-col">
                        <input id="pvUsername" type="hidden">
                        <input id="pvPin" type="hidden">
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Passenger Name</div>
                            <input id="pvPassenger" type="text" placeholder="Full Name">
                        </div>
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Service Type</div>
                            <select id="pvService">
                                <option value="FLIGHT">FLIGHT</option>
                                <option value="LOGISTICS">LOGISTICS</option>
                            </select>
                        </div>
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Generated Credentials</div>
                            <input id="pvCredPreview" type="text" readonly placeholder="Auto-generated on create">
                        </div>
                    </form>

                    <div id="pvFlightFields" class="three-col" style="margin-top:10px;">
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Seat</div>
                            <input id="pvSeat" type="text" placeholder="e.g., 12A">
                        </div>
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Gate</div>
                            <input id="pvGate" type="text" placeholder="e.g., B7">
                        </div>
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Flight Class</div>
                            <select id="pvClass">
                                <option value="Business">Business</option>
                                <option value="First">First</option>
                                <option value="Economy">Economy</option>
                            </select>
                        </div>
                    </div>
                    <div id="pvFlightGeo" class="three-col" style="margin-top:10px;">
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Departure Country</div>
                            <input id="pvDepCountry" type="text" placeholder="e.g., United Kingdom">
                        </div>
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Departure State</div>
                            <input id="pvDepState" type="text" placeholder="e.g., England">
                        </div>
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Destination Country</div>
                            <input id="pvDestCountry" type="text" placeholder="e.g., South Korea">
                        </div>
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Destination State</div>
                            <input id="pvDestState" type="text" placeholder="e.g., Seoul">
                        </div>
                        <div></div>
                        <div></div>
                    </div>

                    <div id="pvLogisticsFields" class="three-col" style="margin-top:10px; display:none;">
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Waybill ID</div>
                            <input id="pvWaybill" type="text" placeholder="e.g., WB-009128">
                        </div>
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Cargo Weight</div>
                            <input id="pvWeight" type="text" placeholder="e.g., 1200kg">
                        </div>
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Vehicle Type</div>
                            <input id="pvVehicle" type="text" placeholder="e.g., Truck / Ship / Air Cargo">
                        </div>
                    </div>
                    <div id="pvLogisticsFields2" class="three-col" style="margin-top:10px; display:none;">
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Delivery Estimate</div>
                            <input id="pvEta" type="text" placeholder="e.g., 2026-06-12 19:30">
                        </div>
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Origin</div>
                            <input id="pvOrigin" type="text" placeholder="Origin address">
                        </div>
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Destination</div>
                            <input id="pvDest" type="text" placeholder="Destination address">
                        </div>
                    </div>
                    <div id="pvLogisticsFields3" class="three-col" style="margin-top:10px; display:none;">
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Courier ID</div>
                            <input id="pvCourier" type="text" placeholder="Courier ID">
                        </div>
                        <div></div>
                        <div></div>
                    </div>

                    <div class="three-col" style="margin-top:10px;">
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Initial Balance</div>
                            <input id="pvBalance" type="text" placeholder="e.g., 186.00" value="186.00">
                        </div>
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Currency</div>
                            <select id="pvCurrency">
                                <option value="£">GBP (£)</option>
                                <option value="$">USD ($)</option>
                                <option value="€">EUR (€)</option>
                            </select>
                        </div>
                        <div></div>
                    </div>

                    <div class="three-col" style="margin-top:10px;">
                        <button class="btn-primary" type="button" id="btnCreateUser">Create User</button>
                        <button class="btn-secondary" type="button" id="btnAutoCred">Generate Credentials (Trip_user####)</button>
                        <button class="btn-secondary" type="button" id="btnResetForm">Reset</button>
                    </div>
                    <div class="two-col" style="margin-top:10px;">
                        <button class="btn-secondary" type="button" id="btnCopyFlightLogin">Copy Flight Login URL</button>
                        <button class="btn-secondary" type="button" id="btnCopyCourierLogin">Copy Courier Login URL</button>
                    </div>
                    <div class="two-col" style="margin-top:10px;">
                        <button class="btn-secondary" type="button" id="btnCopyAccessPortal">Copy Access Portal URL</button>
                        <button class="btn-secondary" type="button" id="btnCopyUserAccessLink" disabled>Copy User Access Link</button>
                    </div>
                    <div id="provisionMsg" style="margin-top:12px; color:var(--text-dim); font-weight:700; min-height:22px;"></div>
                </div>
            </section>

            <section id="secManifest" class="admin-sec" style="display:none;">
                <h2 style="margin:0 0 18px; letter-spacing:-1px;">Manifest Editor</h2>
                <div class="card">
                    <div class="two-col">
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Select Username</div>
                            <select class="user-select" id="manUser"></select>
                        </div>
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Status</div>
                            <select id="manStatus">
                                <option value="ON-HOLD">ON-HOLD</option>
                                <option value="PENDING">PENDING</option>
                                <option value="VERIFYING">VERIFYING</option>
                                <option value="VERIFIED">VERIFIED</option>
                                <option value="CONFIRMED">CONFIRMED</option>
                                <option value="SUSPENDED">SUSPENDED</option>
                                <option value="REJECTED">REJECTED</option>
                                <option value="DECLINED">DECLINED</option>
                                <option value="CANCELLED">CANCELLED</option>
                            </select>
                        </div>
                    </div>
                    <div class="two-col">
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Route (From)</div>
                            <input id="manFrom" type="text" placeholder="LHR">
                        </div>
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Route (To)</div>
                            <input id="manTo" type="text" placeholder="ICN">
                        </div>
                    </div>
                    <div class="three-col">
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Gate</div>
                            <input id="manGate" type="text" placeholder="B-22">
                        </div>
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Seat</div>
                            <input id="manSeat" type="text" placeholder="01-A">
                        </div>
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Flight Class</div>
                            <select id="manClass">
                                <option value="VVIP">VVIP</option>
                                <option value="First">First</option>
                                <option value="Business">Business</option>
                                <option value="Economy">Economy</option>
                            </select>
                        </div>
                    </div>
                    <div style="margin-top:14px; border-top:1px solid var(--border); padding-top:14px;">
                        <div style="font-weight:900; letter-spacing:-0.4px; margin-bottom:10px;">Passenger Details</div>
                        <div class="two-col">
                            <div>
                                <div class="ticket-k" style="margin-bottom:8px;">Category</div>
                                <select id="detCategory">
                                    <option value="">—</option>
                                    <option value="Business Owner">Business Owner</option>
                                    <option value="Family Vacation">Family Vacation</option>
                                    <option value="Couple • Maternity">Couple • Maternity</option>
                                    <option value="High Profile Client">High Profile Client</option>
                                    <option value="Medical Specialist">Medical Specialist</option>
                                    <option value="Private Investor">Private Investor</option>
                                </select>
                            </div>
                            <div>
                                <div class="ticket-k" style="margin-bottom:8px;">Purpose</div>
                                <input id="detPurpose" type="text" placeholder="e.g., Vacation / Medical / Business">
                            </div>
                        </div>
                        <div class="two-col">
                            <div>
                                <div class="ticket-k" style="margin-bottom:8px;">Nationality</div>
                                <input id="detNationality" type="text" placeholder="e.g., British">
                            </div>
                            <div>
                                <div class="ticket-k" style="margin-bottom:8px;">Passport</div>
                                <input id="detPassport" type="text" placeholder="Passport No.">
                            </div>
                        </div>
                        <div>
                            <div class="ticket-k" style="margin-bottom:8px;">Notes</div>
                            <input id="detNotes" type="text" placeholder="Internal notes (visible on Details QR view)">
                        </div>
                    </div>
                    <div style="margin-top:14px; border-top:1px solid var(--border); padding-top:14px;">
                        <div style="font-weight:900; letter-spacing:-0.4px; margin-bottom:10px;">Gateway Details</div>
                        <div class="two-col">
                            <div>
                                <div class="ticket-k" style="margin-bottom:8px;">Terminal</div>
                                <input id="gwTerminal" type="text" placeholder="e.g., T3">
                            </div>
                            <div>
                                <div class="ticket-k" style="margin-bottom:8px;">Check‑in Desk</div>
                                <input id="gwCheckin" type="text" placeholder="e.g., A12">
                            </div>
                        </div>
                        <div class="two-col">
                            <div>
                                <div class="ticket-k" style="margin-bottom:8px;">Baggage</div>
                                <input id="gwBaggage" type="text" placeholder="e.g., Priority Tag">
                            </div>
                            <div>
                                <div class="ticket-k" style="margin-bottom:8px;">Assistance</div>
                                <input id="gwAssist" type="text" placeholder="e.g., Medical / Family / VIP">
                            </div>
                        </div>
                    </div>
                    <div style="margin-top:14px; border-top:1px solid var(--border); padding-top:14px;">
                        <div style="display:flex; justify-content:space-between; align-items:baseline; gap:12px; margin-bottom:10px;">
                            <div style="font-weight:900; letter-spacing:-0.4px;">Additional Passengers</div>
                            <div id="extraCount" style="color:var(--text-dim); font-weight:800; font-size:0.8rem;">0</div>
                        </div>
                        <div class="three-col">
                            <div>
                                <div class="ticket-k" style="margin-bottom:8px;">Name</div>
                                <input id="exName" type="text" placeholder="Full Name">
                            </div>
                            <div>
                                <div class="ticket-k" style="margin-bottom:8px;">Role</div>
                                <input id="exRole" type="text" placeholder="Family / Client / Assistant">
                            </div>
                            <div>
                                <div class="ticket-k" style="margin-bottom:8px;">Class</div>
                                <select id="exClass">
                                    <option value="VVIP">VVIP</option>
                                    <option value="First">First</option>
                                    <option value="Business">Business</option>
                                    <option value="Economy">Economy</option>
                                </select>
                            </div>
                        </div>
                        <div class="two-col">
                            <div>
                                <div class="ticket-k" style="margin-bottom:8px;">Status</div>
                                <select id="exStatus">
                                    <option value="ON-HOLD">ON-HOLD</option>
                                    <option value="PENDING">PENDING</option>
                                    <option value="VERIFYING">VERIFYING</option>
                                    <option value="VERIFIED">VERIFIED</option>
                                    <option value="CONFIRMED">CONFIRMED</option>
                                    <option value="SUSPENDED">SUSPENDED</option>
                                    <option value="REJECTED">REJECTED</option>
                                    <option value="DECLINED">DECLINED</option>
                                    <option value="CANCELLED">CANCELLED</option>
                                </select>
                            </div>
                            <div style="display:grid; align-content:end;">
                                <button class="btn-secondary" type="button" id="btnAddExtra" style="width:100%;">Add Passenger</button>
                            </div>
                        </div>
                        <div id="extraPassengersList" style="display:grid; gap:10px; margin-top:12px;"></div>
                    </div>
                    <div class="two-col" style="margin-top:10px;">
                        <button class="btn-primary" type="button" id="btnSaveManifest">Save Manifest</button>
                        <button class="btn-secondary" type="button" id="btnLoadManifest">Reload</button>
                    </div>
                    <div id="manifestMsg" style="margin-top:12px; color:var(--text-dim); font-weight:700; min-height:22px;"></div>
                </div>
            </section>

            <section id="secFinancial" class="admin-sec" style="display:none;">
                <h2 style="margin:0 0 18px; letter-spacing:-1px;">Financial Control</h2>
                <div class="admin-row">
                    <div class="card">
                        <div class="ticket-k" style="margin-bottom:8px;">Select Username</div>
                        <select class="user-select" id="finUser"></select>
                        <div class="ticket-k" style="margin-bottom:8px;">Ledger Balance (GBP)</div>
                        <input id="finBalance" type="text" placeholder="186.00">
                        <div class="ticket-k" style="margin-bottom:8px;">Quick Adjust</div>
                        <div class="two-col">
                            <input id="finDelta" type="text" placeholder="e.g., 50.00">
                            <div class="two-col" style="gap:8px;">
                                <button class="btn-secondary" type="button" id="btnAddFunds" style="padding:14px 12px;">Add</button>
                                <button class="btn-secondary" type="button" id="btnSubFunds" style="padding:14px 12px;">Subtract</button>
                            </div>
                        </div>
                        <button class="btn-primary" type="button" id="btnSaveBalance">Save Balance</button>
                        <div id="finMsg" style="margin-top:12px; color:var(--text-dim); font-weight:700; min-height:22px;"></div>
                    </div>
                    <div class="card">
                        <div class="ticket-k" style="margin-bottom:8px;">Add Transaction</div>
                        <input id="txDate" type="text" placeholder="Mar 26, 2026">
                        <input id="txDesc" type="text" placeholder="Description">
                        <input id="txAmt" type="text" placeholder="-£24.00 or +£300.00">
                        <input id="txEditIndex" type="hidden" value="">
                        <div class="two-col">
                            <button class="btn-primary" type="button" id="btnAddTx">Add</button>
                            <button class="btn-secondary" type="button" id="btnUpdateTx">Update Selected</button>
                        </div>
                        <div class="two-col" style="margin-top:8px;">
                            <button class="btn-secondary" type="button" id="btnDeleteTx">Delete Selected</button>
                            <button class="btn-secondary" type="button" id="btnClearTx">Clear History</button>
                        </div>
                    </div>
                </div>
                <div class="card table-wrap table-responsive" style="padding:0; overflow:auto;">
                    <table class="m-table">
                        <thead><tr><th>Date</th><th>Description</th><th>Amount</th><th>Action</th></tr></thead>
                        <tbody id="txTable"></tbody>
                    </table>
