                                : '';
                            document.getElementById('adminLoginMsg').textContent = (payloadMsg || 'Invalid passcode.') + hint + flags;
                        } else if (e && e.payload && e.payload.hint) {
                            document.getElementById('adminLoginMsg').textContent = e.payload.hint;
                        } else {
                            document.getElementById('adminLoginMsg').textContent = 'Admin access failed.';
