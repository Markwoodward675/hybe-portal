                let stepSel = (document.getElementById('cmStep') && document.getElementById('cmStep').value) || 'current';
                let idx = -1;
                if (stepSel === 'current') {
                    const cur = parseInt(document.getElementById('logCurrent').value, 10);
                    idx = Number.isFinite(cur) ? (cur - 1) : 0;
                } else {
                    const v = parseInt(stepSel, 10);
                    idx = Number.isFinite(v) ? (v - 1) : 0;
                }
                idx = Math.max(0, Math.min(7, idx));

                user.logistics = ensureLogisticsShape(user.logistics);
