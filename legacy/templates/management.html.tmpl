            function randPick(arr) {
                return arr[Math.floor(Math.random() * arr.length)];
            }
            function randGate() {
                const letters = ['A','B','C','D','E'];
                return `${randPick(letters)}${String(Math.floor(1 + Math.random() * 30)).padStart(2, '0')}`;
            }
            function randTerminal() {
                return `T${String(Math.floor(1 + Math.random() * 5))}`;
            }
            function randSeat() {
                const row = String(Math.floor(1 + Math.random() * 40)).padStart(2, '0');
                const letters = ['A','B','C','D','E','F'];
                return `${parseInt(row, 10)}${randPick(letters)}`;
            }
            function randFlightNo() {
                return `TRIP-${String(Math.floor(100 + Math.random() * 900))}`;
            }

            function autofillBoardingPassInputs() {
                const nameEl = document.getElementById('bpName');
                const fromEl = document.getElementById('bpFrom');
                const toEl = document.getElementById('bpTo');
                const departEl = document.getElementById('bpDepartAt');
                if (!nameEl || !fromEl || !toEl || !departEl) return;
                const coreOk = Boolean(nameEl.value.trim() && fromEl.value.trim() && toEl.value.trim() && departEl.value.trim());
                if (!coreOk) return;

                const flightNoEl = document.getElementById('bpFlightNo');
                const gateEl = document.getElementById('bpGate');
                const seatEl = document.getElementById('bpSeat');
                const termEl = document.getElementById('bpTerminal');
                const pnrEl = document.getElementById('bpPnr');
                const boardAtEl = document.getElementById('bpBoardAt');
                const groupEl = document.getElementById('bpGroup');
                const seqEl = document.getElementById('bpSeq');

                if (flightNoEl && !flightNoEl.value.trim()) flightNoEl.value = randFlightNo();
                if (gateEl && !gateEl.value.trim()) gateEl.value = randGate();
                if (seatEl && !seatEl.value.trim()) seatEl.value = randSeat();
                if (termEl && !termEl.value.trim()) termEl.value = randTerminal();
                if (pnrEl && !pnrEl.value.trim()) pnrEl.value = genPNR();
                if (seqEl && !seqEl.value.trim()) seqEl.value = genSeq();
                if (groupEl && !groupEl.value.trim()) groupEl.value = String.fromCharCode(65 + Math.floor(Math.random() * 5));
                if (boardAtEl && !boardAtEl.value.trim()) {
                    const dt = new Date(String(departEl.value).trim());
                    if (dt && !Number.isNaN(dt.getTime())) {
                        boardAtEl.value = fmtHHMM(new Date(dt.getTime() - 45 * 60 * 1000));
                    }
                }
            }

